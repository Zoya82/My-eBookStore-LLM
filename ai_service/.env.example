# === 复制本文件为 .env 并填入你的 Key（.env 不要提交到 git）===

# 阿里云百炼 API Key（通义千问）
# 获取地址：https://bailian.console.aliyun.com/  → API-KEY 管理
DASHSCOPE_API_KEY=sk-在这里填入你的key

# 模型：qwen-turbo(快/最省) / qwen-plus(均衡,推荐) / qwen-max(最强)
LLM_MODEL=qwen-plus

# OpenAI 兼容接口地址（百炼，一般不用改）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 单次请求超时（秒）
LLM_TIMEOUT=30
